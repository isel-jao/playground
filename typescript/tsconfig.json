{
  "compilerOptions": {
    "strict": true,
    "target": "es2024",
    "module": "nodenext",
    "lib": ["ES2024", "DOM"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
